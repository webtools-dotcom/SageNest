VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
# Deprecated (migrate to hash vars below): use one admin email, or set VITE_ADMIN_EMAILS as a comma-separated allowlist.
# VITE_ADMIN_EMAIL=admin@example.com
# VITE_ADMIN_EMAILS=admin@example.com,editor@example.com

# SHA-256 hash of admin email(s). Generate with: echo -n "admin@example.com" | sha256sum
# VITE_ADMIN_EMAIL_HASH=<hash_of_admin_email>
# VITE_ADMIN_EMAIL_HASHES=<hash1>,<hash2>  (for multiple admins)
